syntax on
set ts=2 sw=2 sts=2
set et ai cin nu sm ru cul
set mouse=a title wim=list nowrap ls=2
set ml sc
set mls=5
set fdm=marker
colo desert

im <C-S> <esc>:w<CR>
nn <C-S> :w<CR>
nn <space> za

" 使用 Windows 环境时可能需要
"   set shell=powershell
"   set backspace=indent,eol,start
"   set nocompatible
" set sh=powershell bs=indent,eol,start nocp
"
" 如果 <C-S> 导致 vim 卡死
" 在 .bashrc 里加一句 stty -ixon