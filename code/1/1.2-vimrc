syntax on
set ts=2 sw=2 sts=2
set et ai cin nu sm ru cul
set mouse=a title wim=list nowrap ls=2
set ml sc
set mls=5
set fdm=marker
colo desert

im <C-S> <esc>:w<CR>
nn <C-S> :w<CR>
nn <space> za

"   set shell=powershell
"   set backspace=indent,eol,start
"   set nocompatible
" set sh=powershell bs=indent,eol,start nocp